float SHT41_ReadTemperature(void) 

{ 

uint8_t cmd = 0xFD; 

uint8_t rx_data[6]; 

uint16_t raw_temp; 

float temperature; 

 
 

HAL_I2C_Master_Transmit(&hi2c1, SHT41_ADDR, &cmd, 1, HAL_MAX_DELAY); /*stm sends msg to sensor to start measurement */ 

 
 

HAL_Delay(10); /* sensor meas. time 8-10 ms approx*/ 

 
 

HAL_I2C_Master_Receive(&hi2c1, SHT41_ADDR, rx_data, 6, HAL_MAX_DELAY); /* sensor returns 6 bytes*/ 

 
 

raw_temp = (rx_data[0] << 8) | rx_data[1]; /*combines LSB and MSB to form 16 bit value */ 

 
 

temperature = -45 + 175 * ((float)raw_temp / 65535.0); /*formula from sht41 datasheet */ 

 
 

return temperature; 

} 

 
 

